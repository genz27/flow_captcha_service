# ============================================================
# flow_captcha_service subnode — 环境变量配置模板
# 复制本文件为 .env，按本机实际情况修改后启动：
#   docker compose -f docker-compose.cluster.subnode.yml up -d --build
# ============================================================

# ---------- 监听端口 ----------
PORT=8060

# ---------- 管理员账号（与 master 保持一致）----------
FCS_ADMIN_USERNAME=sangka
FCS_ADMIN_PASSWORD=tuqYHE5FnNPPMAuS

# ---------- 日志级别 ----------
FCS_LOG_LEVEL=INFO

# ---------- 集群标识（每台服务器必须不同）----------
FCS_NODE_NAME=subnode-1        # 改为 subnode-2 / subnode-3 / subnode-4
# 代理网关 session ID 前缀，必须全局唯一，建议与 FCS_NODE_NAME 保持一致
CLUSTER_NODE_IDENTIFIER=subnode-1   # 改为 subnode-2 / subnode-3 / subnode-4

# ---------- 浏览器并发数 ----------
FCS_BROWSER_COUNT=10

# ---------- 集群连接 ----------
FCS_CLUSTER_MASTER_BASE_URL=http://47.79.239.184:8060
FCS_CLUSTER_MASTER_CLUSTER_KEY=fcs_cluster_nwfbL6_KntfIRuujcqz1TFFrmy38Ea4G
# 本机对外地址，master 用此地址回调
FCS_CLUSTER_NODE_PUBLIC_BASE_URL=http://<本机公网IP>:8060
FCS_CLUSTER_NODE_API_KEY=DD46E534-9E6B-4C63-B04C-8ABEBA579E51
FCS_CLUSTER_NODE_WEIGHT=100
FCS_CLUSTER_NODE_MAX_CONCURRENCY=0

# ---------- 代理（session affinity 模式）----------
FCS_BROWSER_PROXY_ENABLED=true
# {session_id} 会被自动替换为 {CLUSTER_NODE_IDENTIFIER}_slot_{browser_id}
FCS_BROWSER_PROXY_URL=http://{session_id}:x@47.79.239.184:7896

# ---------- 指纹与行为（默认值已适配生产，通常不需要改）----------
BROWSER_FINGERPRINT_MODE=fixed_per_slot
BROWSER_CAPTCHA_DWELL_SECONDS=15
BROWSER_DWELL_BACKGROUND_ONLY=true
BROWSER_SOLVE_MIN_INTERVAL_SECONDS=30
FCS_BROWSER_STANDBY_TOKEN_TTL_SECONDS=90
